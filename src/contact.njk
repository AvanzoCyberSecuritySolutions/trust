                <address class="not-italic text-lg text-[#5c4033] font-light leading-relaxed">
                  NRA-89, Whitefield, Puthurakkara<br>
                  Ayyanthole, Thrissur. 680003
                </address>
              </div>
            </div>

            <!-- Business Hours -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-2xl bg-[#5c4033]/5 flex items-center justify-center shrink-0">
