            </div>
          </div>
        </div>

        <!-- Map Element to Balance Space -->
        <div class="mt-12 rounded-[2rem] overflow-hidden shadow-sm border border-[#5c4033]/5 h-64 relative bg-[#f5ebd9]">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3922.7842323565257!2d76.19532821431604!3d10.517376492500858!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ba7ee4c40590a23%3A0x82b9a715f5c35c9!2sAyyanthole%2C%20Thrissur%2C%20Kerala%20680003!5e0!3m2!1sen!2sin!4v1689874837890!5m2!1sen!2sin" 
            width="100%" 
            height="100%" 
            style="border:0; filter: grayscale(70%) sepia(20%) hue-rotate(340deg) opacity(90%);" 
