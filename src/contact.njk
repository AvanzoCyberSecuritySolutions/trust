        <h2 class="text-2xl font-bold font-[Georgia] text-[#5c4033] mb-8">Send a Message</h2>
        
        <form id="contactForm" class="space-y-6">
          <input type="hidden" name="access_key" value="419554fe-62b1-4d6d-a239-e8989ae9dc56">
          <input type="hidden" name="subject" value="New Inquiry for Avanzo Trust">
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <div>
            <label for="contactName" class="block text-sm font-medium text-[#5c4033]/80 mb-2">Name</label>
            <input type="text" id="contactName" name="name" required
              class="w-full bg-[#5c4033]/5 border-none rounded-2xl px-6 py-4 text-[#5c4033] focus:ring-2 focus:ring-[#5c4033]/20 transition-shadow outline-none placeholder:text-[#5c4033]/40" placeholder="John Doe">
          </div>

          <div>
            <label for="contactEmail" class="block text-sm font-medium text-[#5c4033]/80 mb-2">Email Address</label>
            <input type="email" id="contactEmail" name="email" required
              class="w-full bg-[#5c4033]/5 border-none rounded-2xl px-6 py-4 text-[#5c4033] focus:ring-2 focus:ring-[#5c4033]/20 transition-shadow outline-none placeholder:text-[#5c4033]/40" placeholder="john@example.com">
          </div>

          <div>
            <label for="contactMessage" class="block text-sm font-medium text-[#5c4033]/80 mb-2">Message</label>
            <textarea id="contactMessage" name="message" rows="4" required
              class="w-full bg-[#5c4033]/5 border-none rounded-2xl px-6 py-4 text-[#5c4033] focus:ring-2 focus:ring-[#5c4033]/20 transition-shadow outline-none resize-none placeholder:text-[#5c4033]/40" 
              placeholder="How can we help you?"></textarea>
          </div>

          <button type="submit"
            class="w-full bg-[#5c4033] text-white rounded-2xl px-6 py-4 font-medium text-lg hover:bg-[#4a3328] hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
            Send Message
          </button>
          
          <p id="contactFormMessage" class="text-sm mt-4 font-medium text-center hidden"></p>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- JavaScript to Handle Form Submission -->
<script>
  const form = document.getElementById('contactForm');
  const result = document.getElementById('contactFormMessage');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    result.innerHTML = "Please wait...";
    result.classList.remove('hidden', 'text-green-600', 'text-red-600');
    result.classList.add('text-gray-600');

    fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
        },
        body: json
    })
    .then(async (response) => {
        let json = await response.json();
        if (response.status == 200) {
            result.innerHTML = "Thank you! Your message has been sent.";
            result.classList.remove('text-gray-600', 'text-red-600');
            result.classList.add('text-green-600'); // Green for success
            form.reset();
        } else {
            console.log(response);
            result.innerHTML = json.message || "Something went wrong.";
            result.classList.remove('text-gray-600', 'text-green-600');
            result.classList.add('text-red-600'); // Red for error
        }
    })
    .catch(error => {
        console.log(error);
        result.innerHTML = "Something went wrong!";
        result.classList.remove('text-gray-600', 'text-green-600');
        result.classList.add('text-red-600');
    })
    .finally(() => {
        // Hide the message after 5 seconds
        setTimeout(() => {
            result.classList.add('hidden');
            result.innerHTML = ""; 
        }, 5000);
    });
  });
</script>
