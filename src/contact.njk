---
layout: layouts/base.njk
title: "Contact Us"
---

<!-- Contact Section -->
  
<section class="max-w-7xl mx-auto px-6 py-16 mt-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

    <!-- Left Column (Form) -->
    <div>
      <h2 class="text-4xl font-bold font-[Georgia] text-[#5c4033] mb-8">CONTACT US</h2>

      <form id="contactForm" class="space-y-6">
        
        <!-- IMPORTANT: PASTE YOUR NEW ACCESS KEY BELOW -->
        <!-- Go to web3forms.com, enter info@avanzotrust.in to get this key -->
        <input type="hidden" name="access_key" value="419554fe-62b1-4d6d-a239-e8989ae9dc56">
        
        <!-- Optional: Ensures the email subject line is clear -->
        <input type="hidden" name="subject" value="New Inquiry for Avanzo Trust">
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

        <!-- Name -->
        <div>
          <label for="contactName" class="sr-only">Name</label>
          <input type="text" id="contactName" name="name" placeholder="Name" required
            class="w-full border border-[#5c4033] p-3 rounded-md focus:outline-none focus:ring-2 focus:ring-[#5c4033]">
        </div>

        <!-- Email -->
        <div>
          <label for="contactEmail" class="sr-only">Email Address</label>
          <input type="email" id="contactEmail" name="email" placeholder="Email Address" required
            class="w-full border border-[#5c4033] p-3 rounded-md focus:outline-none focus:ring-2 focus:ring-[#5c4033]">
        </div>

        <!-- Phone -->
        <!-- <div>
          <label for="contactPhone" class="sr-only">Phone Number</label>
          <input type="tel" id="contactPhone" name="phone" placeholder="Phone Number"
            class="w-full border border-[#5c4033] p-3 rounded-md focus:outline-none focus:ring-2 focus:ring-[#5c4033]">
        </div> -->

        <!-- Message -->
        <div>
          <label for="contactMessage" class="sr-only">Message</label>
          <textarea id="contactMessage" name="message" rows="5" placeholder="Message" required
            class="w-full border border-[#5c4033] p-3 rounded-md focus:outline-none focus:ring-2 focus:ring-[#5c4033]"></textarea>
        </div>

        <!-- Submit Button -->
        <button type="submit"
          class="bg-[#5c4033] text-white px-6 py-3 rounded-md font-semibold hover:bg-[#4a3328] transition w-full md:w-auto">
          Submit
        </button>

        <!-- Success/Error Message Display -->
        <p id="contactFormMessage" class="text-sm mt-4 font-semibold hidden"></p>
      </form>
    </div>

    <!-- Right Column (Info) -->
    <div class="bg-[#f5f5dc] p-8 rounded-md shadow-md">
      <h3 class="text-2xl font-bold font-[Georgia] text-[#5c4033] mb-4">Get in Touch</h3>

      <div class="space-y-4 text-black">
        <div>
          <p class="font-semibold text-[#5c4033]">Phone/WhatsApp</p>
          <p>+91 8129771111</p>
        </div>

        <div>
          <p class="font-semibold text-[#5c4033]">Email</p>
          <p>info@avanzotrust.in</p>
        </div>

        <div>
          <p class="font-semibold text-[#5c4033]">Address</p>
          <p>NRA-89, Whitefield, Puthurakkara, Ayyanthole,<br> Thrissur. 680003</p>
        </div>

        <div>
          <p class="font-semibold text-[#5c4033]">Business Hours</p>
          <p>Monday through Saturday<br>Open 8am – 12pm</p>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- JavaScript to Handle Form Submission -->
<script>
  const form = document.getElementById('contactForm');
  const result = document.getElementById('contactFormMessage');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    result.innerHTML = "Please wait...";
    result.classList.remove('hidden', 'text-green-600', 'text-red-600');
    result.classList.add('text-gray-600');

    fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
        },
        body: json
    })
    .then(async (response) => {
        let json = await response.json();
        if (response.status == 200) {
            result.innerHTML = "Thank you! Your message has been sent.";
            result.classList.remove('text-gray-600', 'text-red-600');
            result.classList.add('text-green-600'); // Green for success
            form.reset();
        } else {
            console.log(response);
            result.innerHTML = json.message || "Something went wrong.";
            result.classList.remove('text-gray-600', 'text-green-600');
            result.classList.add('text-red-600'); // Red for error
        }
    })
    .catch(error => {
        console.log(error);
        result.innerHTML = "Something went wrong!";
        result.classList.remove('text-gray-600', 'text-green-600');
        result.classList.add('text-red-600');
    })
    .finally(() => {
        // Hide the message after 5 seconds
        setTimeout(() => {
            result.classList.add('hidden');
            result.innerHTML = ""; 
        }, 5000);
    });
  });
</script>
