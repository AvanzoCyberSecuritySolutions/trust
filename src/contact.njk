                <p class="text-sm font-semibold text-[#5c4033]/60 uppercase tracking-wider mb-1">Phone / WhatsApp</p>
                <a href="tel:+918129771111" class="text-xl font-medium text-[#5c4033] hover:text-[#5c4033]/70 transition-colors">+91 812977 1111</a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-2xl bg-[#5c4033]/5 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[#5c4033]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-[#5c4033]/60 uppercase tracking-wider mb-1">Email</p>
