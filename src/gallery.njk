---
layout: layouts/base.njk
title: "Gallery"
description: "Explore the Avanzo Charitable Trust gallery: photos and highlights from our cyber awareness campaigns and events."
---

<style>
  /* Scroll Reveal State */
  .reveal-item {
    opacity: 0;
    transform: translateY(2rem) scale(0.98);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-item.is-revealed {
    opacity: 1;
    transform: none;
  }

  /* Lightbox transition */
  dialog#lightbox {
    transition: opacity 0.4s ease-out;
  }

  dialog#lightbox:not([open]) {
    display: none;
  }

  /* Stop body scroll when lightbox open */
  body:has(dialog#lightbox[open]) {
    overflow: hidden;
  }

  /* Masonry layout fix */
  .gallery-grid {
    column-count: 1;
    column-gap: 2rem;
    column-fill: balance;
  }

  @media (min-width: 640px) {
    .gallery-grid {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      column-count: 3;
    }
  }

  .gallery-grid > img {
    display: block;
    width: 100%;
    height: auto;
    margin: 0 0 2rem;
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
  }
</style>

