<header>
  <div class="logo">
    <a href="/">
      <img src="{{ site.logoNav }}" alt="{{ site.name }} Logo" class="cursor-pointer">
    </a>
  </div>

  <nav>
    <ul class="nav-links">
      {%- for item in navigation.main %}
        {%- if item.dropdown %}
          <li class="dropdown">
            <a href="#">{{ item.label }} ▾</a>
            <ul class="dropdown-menu">
              {%- for sub in item.items %}
                <li><a href="{{ sub.url }}"{% if sub.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ sub.label }}</a></li>
              {%- endfor %}
            </ul>
          </li>
        {%- else %}
          <li><a href="{{ item.url }}"{% if item.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ item.label }}</a></li>
        {%- endif %}
      {%- endfor %}
      <li class="search-container">
        <a href="#" id="search-toggle">
          <img src="/assets/images/misc/search-icon.png" alt="Search" class="search-icon">
        </a>
        <input type="text" id="search-box" placeholder="Search">
      </li>
    </ul>

    <!-- Mobile Menu Button -->
    <div class="menu-toggle">&#9776;</div>
  </nav>
</header>
