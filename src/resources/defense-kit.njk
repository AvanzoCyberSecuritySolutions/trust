---
layout: layouts/base.njk
title: "Personal Defense Kit"
---

<!-- Header -->
  <div id="header-container" class="no-print"></div>
  <script src="js/header.js"></script>

  <!-- Content Section -->
  <section class="pt-32 pb-16 max-w-5xl mx-auto px-4 md:px-6">
    <div id="printable-area" class="bg-[#fdf8f3] rounded-xl shadow-2xl border border-[#e5d6c3] overflow-hidden">
      <!-- Dark Brown Header -->
      <div class="bg-[#5c4033] p-8 md:p-10 relative">
        <!-- Decorative circles matching index.html -->
        <div class="absolute -bottom-16 -left-16 w-52 h-52 rounded-full border-[45px] border-white/5 pointer-events-none"></div>
        <div class="absolute -top-8 -right-8 w-32 h-32 rounded-full border-[32px] border-white/5 pointer-events-none"></div>

        <div class="relative z-10 flex justify-between items-start mb-4">
          <span class="inline-block bg-white/15 text-[#f7e9d7] text-[11px] font-medium tracking-widest uppercase px-4 py-1.5 rounded-full border border-white/20">
            DEFENSE BLUEPRINT
          </span>
          <a href="/" class="no-print bg-white/10 hover:bg-[#f7e9d7] hover:text-[#5c4033] text-white text-sm font-medium px-4 py-2 rounded-md transition-all duration-200 flex items-center border border-white/20">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            Home / Back
          </a>
        </div>
        <h1 class="relative z-10 text-3xl md:text-4xl font-[Georgia] font-bold text-white mb-3 leading-tight">Personal Cyber Defense Kit</h1>
        <p class="relative z-10 text-[#f7e9d7] text-lg max-w-3xl leading-relaxed">
          Configure and export a personalized security roadmap. Cross off tasks as you secure your environment.
        </p>
      </div>

      <!-- Main Body -->
      <div class="p-8 md:p-10">
        <p class="text-[#6b5040] mb-8 text-[15px] leading-relaxed">
          Select the cyber defense layers you wish to customize. Once configured, you can download or print your home roadmap.
        </p>

        <!-- List of Layers -->
        <div class="space-y-5">
          
          <!-- Layer 1 -->
          <label class="flex items-start p-6 bg-white border border-[#e5d6c3] rounded-xl cursor-pointer hover:-translate-y-1 hover:shadow-lg transition-transform duration-300">
            <div class="flex-shrink-0 mt-0.5">
              <input type="checkbox" checked class="custom-checkbox" />
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-bold text-[#3b1f0e] mb-1">Layer 1: Strong Credential Armor</h3>
              <p class="text-[#7a5a3a] text-sm md:text-[15px] leading-relaxed">Deploy a strong password manager and systematically rotate duplicate credentials on your central digital profiles.</p>
            </div>
          </label>

          <!-- Layer 2 -->
          <label class="flex items-start p-6 bg-white border border-[#e5d6c3] rounded-xl cursor-pointer hover:-translate-y-1 hover:shadow-lg transition-transform duration-300">
            <div class="flex-shrink-0 mt-0.5">
              <input type="checkbox" checked class="custom-checkbox" />
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-bold text-[#3b1f0e] mb-1">Layer 2: Multi-Factor Activation (MFA)</h3>
              <p class="text-[#7a5a3a] text-sm md:text-[15px] leading-relaxed">Mandate 2FA setups on your main emails (Gmail/Yahoo/Outlook) and active banking apps. Avoid relying strictly on SMS OTPs where possible.</p>
            </div>
          </label>

          <!-- Layer 3 -->
          <label class="flex items-start p-6 bg-white border border-[#e5d6c3] rounded-xl cursor-pointer hover:-translate-y-1 hover:shadow-lg transition-transform duration-300">
            <div class="flex-shrink-0 mt-0.5">
              <input type="checkbox" checked class="custom-checkbox" />
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-bold text-[#3b1f0e] mb-1">Layer 3: Router Encryption & Network Armor</h3>
              <p class="text-[#7a5a3a] text-sm md:text-[15px] leading-relaxed">Change default factory logins on your Wi-Fi router. Secure the router setup using WPA3 encryption.</p>
            </div>
          </label>

          <!-- Layer 4 -->
          <label class="flex items-start p-6 bg-white border border-[#e5d6c3] rounded-xl cursor-pointer hover:-translate-y-1 hover:shadow-lg transition-transform duration-300">
            <div class="flex-shrink-0 mt-0.5">
              <input type="checkbox" checked class="custom-checkbox" />
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-bold text-[#3b1f0e] mb-1">Layer 4: Social Perimeter Check</h3>
              <p class="text-[#7a5a3a] text-sm md:text-[15px] leading-relaxed">Clamp down on public visibility metrics inside your Facebook, Instagram, and LinkedIn accounts. Hide sensitive phone numbers and emails.</p>
            </div>
          </label>

        </div>

      </div>
    </div>
    
    <!-- Action Buttons -->
    <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4 no-print">
      <button onclick="openEmailModal()" class="bg-[#5c4033] hover:bg-[#8b4513] text-white px-8 py-3 rounded-full font-semibold text-[15px] transition-all duration-200 flex items-center justify-center shadow-lg hover:scale-105">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        Email My Kit
      </button>
    </div>

    <!-- Email Modal -->
    <div id="emailModal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm transition-opacity no-print">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden transform scale-95 opacity-0 transition-all duration-300" id="emailModalContent">
        <div class="bg-[#5c4033] p-6 text-white relative">
          <button onclick="closeEmailModal()" class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
          <h2 class="text-2xl font-[Georgia] font-bold mb-1">Get Your PDF Guide</h2>
          <p class="text-[#f7e9d7] text-sm">We'll email you a customized security checklist based on your selections.</p>
        </div>
        <div class="p-6">
          <form id="emailForm" onsubmit="handleEmailSubmit(event)">
            <div class="mb-5">
              <label for="userEmail" class="block text-sm font-bold text-[#5c4033] mb-2">Email Address</label>
              <input type="email" id="userEmail" required placeholder="you@example.com" class="w-full px-4 py-3 rounded-lg border border-[#e5d6c3] focus:border-[#5c4033] focus:ring-2 focus:ring-[#5c4033]/20 outline-none transition-all text-[#3b1f0e]">
            </div>
            
            <div id="formStatus" class="hidden mb-4 p-3 rounded-lg text-sm font-medium"></div>

            <button type="submit" id="submitEmailBtn" class="w-full bg-[#5c4033] hover:bg-[#8b4513] text-white py-3 rounded-lg font-bold transition-colors flex items-center justify-center">
              Send PDF Guide
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <div id="footer-container" class="no-print"></div>
  <script src="js/footer.js"></script>
