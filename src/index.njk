  <style>
    /* Swiper Container */
    .poster-swiper-container {
      width: 100%;
      padding: 2rem 0;
      overflow: hidden;
    }
    .poster-swiper {
      width: 100%;
      padding-top: 30px;
      padding-bottom: 50px;
    }
    /* Slide sizing */
    .poster-swiper .swiper-slide {
      width: 270px;
      height: 380px;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      box-shadow: 0 10px 20px rgba(0,0,0,0.4);
    }
    
    .poster-swiper .swiper-slide img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Continuous ticker tape styling */
    .poster-swiper .swiper-wrapper {
      transition-timing-function: linear !important;
    }

    /* Swiper Pagination Styling */
    .poster-swiper .swiper-pagination-bullet {
      background: rgba(253, 248, 243, 0.4);
      opacity: 1;
      width: 10px;
      height: 10px;
      transition: all 0.3s ease;
    }
    .poster-swiper .swiper-pagination-bullet-active {
      background: #fdf8f3;
      transform: scale(1.4);
    }
  </style>

